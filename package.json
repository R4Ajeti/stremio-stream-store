{
  "name": "stremio-stream-store",
  "version": "1.0.0",
  "description": "A Stremio addon for saving and serving one custom stream link per movie or TV episode.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "stremio",
    "stremio-addon",
    "fastify",
    "firebase",
    "vercel"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/static": "^7.0.4",
    "@vercel/analytics": "^2.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "firebase-admin": "^12.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20"
  }
}
