FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY_BASE64=base64-encoded-private-key
FIREBASE_DATABASE_URL=https://your-firebase-project-id.firebaseio.com

ADDON_BASE_URL=http://localhost:3000
PORT=3000

# Recommended in production. When set, saving links requires:
# Authorization: Bearer <LINK_WRITE_TOKEN>
LINK_WRITE_TOKEN=

# Optional route analytics controls.
ANALYTICS_ENABLED=true
ANALYTICS_READ_TOKEN=
ANALYTICS_TIME_ZONE=UTC
ANALYTICS_IP_SALT=replace-with-a-long-random-secret
