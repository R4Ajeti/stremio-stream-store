{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index.ts"
    },
    {
      "source": "/set",
      "destination": "/api/index.ts"
    },
    {
      "source": "/ui/analytics/routes",
      "destination": "/api/index.ts"
    },
    {
      "source": "/health",
      "destination": "/api/index.ts"
    },
    {
      "source": "/manifest.json",
      "destination": "/api/index.ts"
    },
    {
      "source": "/favicon.ico",
      "destination": "/api/index.ts"
    },
    {
      "source": "/public/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/stream/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/api/analytics/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/api/link/(.*)",
      "destination": "/api/index.ts"
    }
  ]
}
